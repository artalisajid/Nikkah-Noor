# Free SMTP provider setup for Supabase Auth email OTP.
# Recommended free provider: Brevo SMTP relay.
# Copy to .env.smtp.local and fill with your verified Brevo SMTP credentials.

SUPABASE_PROJECT_REF=xytrrmlkriazmziejkkt
SUPABASE_ACCESS_TOKEN=

SMTP_PROVIDER=brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Use your verified Brevo sender email. For local testing this can be a
# verified Gmail/Outlook/etc. address; move to no-reply@your-domain later.
SMTP_ADMIN_EMAIL=
SMTP_SENDER_NAME=Nikkah Noor
